http {
  types_hash_max_size 2048;
  include mime.types;
  charset UTF-8;
  server {
    root /dist;
    index index.html;

    location / {
      {{ if ne $.NGINX_DEFAULT_REQUEST "" }}
        try_files $uri $uri/ /{{ $.NGINX_DEFAULT_REQUEST }};
      {{ else }}
        try_files $uri $uri/ =404;
      {{ end }}
    }
  }
}