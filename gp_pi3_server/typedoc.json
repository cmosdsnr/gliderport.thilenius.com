{
    "name": "Gliderport Pi3 Server",
    "entryPoints": [
        "src/*.ts",
        "src/*/*.ts",
        "index.d.ts"
      ],
    "out": "docs",
    "excludePrivate": true,
    "readme": "Readme.md",
    "includeVersion": true,
    "highlightLanguages": ["ts", "tsx", "json", "bash", "powershell", "perl"],
    "useFirstParagraphOfCommentAsSummary": true
  }