    "mysql2": "^2.3.3",
    "nodemailer": "^6.9.0",
    "request": "^2.88.2",
    "suncalc": "^1.9.0",
    "typescript": "^4.9.5",
    "vite": "^3.0.9",
    "ws": "^8.8.1"
  },
  "devDependencies": {
